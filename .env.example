# ─── Strava API ───────────────────────────────────────────────────────────────
# Register your app at: https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Share your sheet publicly (View only) → copy the ID from the URL
# URL format: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
# Required tabs: Skills | Content | Photos

GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ─── Sync Behaviour ───────────────────────────────────────────────────────────
# Set to false to generate JSON files without pushing to GitHub
AUTO_PUSH=true
